@model HotelBooking.Web.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title text-center">Вход в систему</h2>

                    <!-- Отображение ошибок -->
                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0">@error.ErrorMessage</p>
                            }
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <div class="mb-3">
                            <label for="Email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="Email" name="Email" required value="@Model?.Email">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label for="Password" class="form-label">Пароль</label>
                            <input type="password" class="form-control" id="Password" name="Password" required>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Войти</button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <p>Нет аккаунта? <a href="/Account/Register">Зарегистрироваться</a></p>
                    </div>

                    <!-- Тестовые данные -->
                    <div class="mt-4 p-3 bg-light rounded">
                        <h6>Тестовые аккаунты:</h6>
                        <p class="mb-1"><strong>Админ:</strong> admin@hotelbooking.com / Admin123!</p>
                        <p class="mb-0"><strong>Клиент:</strong> client@test.com / Client123!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>