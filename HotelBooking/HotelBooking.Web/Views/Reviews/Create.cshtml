@{
    ViewData["Title"] = "Оставить отзыв";
    var hotel = ViewBag.Hotel as HotelBooking.Application.DTOs.HotelDto;
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Hotels" asp-action="Index">Отели</a></li>
            <li class="breadcrumb-item"><a asp-controller="Hotels" asp-action="Details" asp-route-id="@hotel?.Id">@hotel?.Name</a></li>
            <li class="breadcrumb-item"><a asp-controller="Reviews" asp-action="Index" asp-route-hotelId="@hotel?.Id">Отзывы</a></li>
            <li class="breadcrumb-item active" aria-current="page">Новый отзыв</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4>Оставить отзыв об отеле @hotel?.Name</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> 
                        Вы можете оставлять отзывы только на отели, в которых останавливались.
                    </div>

                    <form asp-action="Create" method="post" id="reviewForm">
                        <input type="hidden" name="hotelId" value="@hotel?.Id" />

                        <div class="mb-4">
                            <label class="form-label">Оценка *</label>
                            <div class="star-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <input type="radio" name="rating" value="@i" id="star@i" class="star-input" />
                                    <label for="star@i" class="star-label">
                                        <i class="bi bi-star-fill"></i>
                                    </label>
                                }
                            </div>
                            <input type="hidden" name="selectedRating" id="selectedRating" required />
                            <div class="invalid-feedback" id="ratingError" style="display:none;">Пожалуйста, выберите оценку</div>
                        </div>

                        <div class="mb-3">
                            <label for="comment" class="form-label">Отзыв</label>
                            <textarea 
                                name="comment" 
                                id="comment" 
                                class="form-control" 
                                rows="5" 
                                maxlength="1000"
                                placeholder="Поделитесь своими впечатлениями об отеле..."
                                required></textarea>
                            <div class="form-text">Максимум 1000 символов</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i> Отправить отзыв
                            </button>
                            <a asp-action="Index" asp-route-hotelId="@hotel?.Id" class="btn btn-outline-secondary">
                                Отмена
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const starInputs = document.querySelectorAll('.star-input');
    const starLabels = document.querySelectorAll('.star-label');
    
    // Обработка клика на звезду
    starInputs.forEach(function(input) {
        input.addEventListener('change', function() {
            const selectedValue = parseInt(this.value);
            
            // Подсвечиваем звезды от 1 до выбранной
            starLabels.forEach(function(label, index) {
                // Инвертируем порядок, т.к. звезды идут от 5 к 1
                const starValue = 5 - index;
                if (starValue <= selectedValue) {
                    label.style.color = '#ffc107';
                } else {
                    label.style.color = '#ddd';
                }
            });
        });
    });
});

// Валидация формы
document.getElementById('reviewForm').addEventListener('submit', function(e) {
    const rating = document.querySelector('input[name="rating"]:checked');
    const hiddenInput = document.getElementById('selectedRating');
    const errorDiv = document.getElementById('ratingError');
    
    if (!rating) {
        e.preventDefault();
        errorDiv.style.display = 'block';
        return false;
    }
    
    errorDiv.style.display = 'none';
    hiddenInput.value = rating.value;
});
</script>

<style>
.star-rating {
    display: flex;
    flex-direction: row;
    gap: 5px;
}
.star-input {
    display: none;
}
.star-label {
    cursor: pointer;
    font-size: 2rem;
    color: #ddd;
    transition: color 0.2s;
}
.star-label:hover {
    color: #ffc107;
}
</style>
