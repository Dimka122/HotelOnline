@model HotelBooking.Application.DTOs.HotelDto
@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2>@Model.Name</h2>
            <p class="text-muted">@Model.Address</p>
            <p>@Model.Description</p>

            <div class="mt-4">
                <h4>Hotel Information</h4>
                <ul>
                    <li>Number of rooms: @Model.RoomCount</li>
                    <li>Prices from: $@Model.MinPrice to $@Model.MaxPrice</li>
                </ul>
            </div>

            <!-- Секция отзывов -->
            <div class="mt-4">
                <div class="d-flex justify-content-between align-items-center">
                    <h4>Reviews</h4>
                    <a asp-controller="Reviews" asp-action="Index" asp-route-hotelId="@Model.Id" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-star"></i> View Reviews
                    </a>
                </div>
                <p class="text-muted">Check out what other guests say about this hotel.</p>
            </div>
        </div>
        <div class="col-md-4">
            <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name">
        </div>
    </div>

    <div class="mt-4">
        <a href="/Hotels" class="btn btn-secondary">← Back to hotels list</a>
    </div>
</div>